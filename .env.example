# Supabase — required for Moti AI mode
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API key — set as a Supabase secret (not here!)
# Run: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...

# Token encryption — set as a Supabase secret
# Run: supabase secrets set TOKEN_ENCRYPTION_KEY=your-random-32-char-secret
